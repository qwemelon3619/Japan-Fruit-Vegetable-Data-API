# Copy to .env and set real values.
# Never commit .env or any file that contains real secrets.

# App
APP_NAME=japan-data-platform
APP_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_PORT=8080

# PostgreSQL (required)
POSTGRES_USER=change_me_db_user
POSTGRES_PASSWORD=change_me_long_random_password
POSTGRES_DB=analyticsdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
POSTGRES_TIMEZONE=Asia/Tokyo

# Docker Compose networking
# Keep bind addresses at 127.0.0.1 unless you explicitly want public exposure.
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_EXPOSE_PORT=5444
API_BIND_ADDRESS=127.0.0.1
API_EXPOSE_PORT=8080

# Scheduler
DAILY_INGEST_SCHEDULE=0 10 * * *
MONITOR_SNAPSHOT_SCHEDULE=*/5 * * * *
